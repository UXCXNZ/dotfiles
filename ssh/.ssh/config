# SSH Config
#
# Naming convention:
#   "macmini"  / "mac-mini"   = local network / Tailscale
#   "macstudio" / "mac-studio" = local network / Tailscale
#
# Machine users:
#   Mac Mini (M1)    — user: krs
#   Mac Studio (M4)  — user: chris
#   MacBook Pro      — user: chris (Tailscale only)
#
# Key auth: ssh-copy-id <user>@<ip> if password prompted

# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# Comment this line if you don't want it to be added again.
Include ~/.orbstack/ssh/config

# --- Mac Mini (M1) ---
Host macmini
  HostName 192.168.1.202  # Local network
  User krs
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes

Host mac-mini
  HostName 100.92.41.65   # Tailscale
  User krs
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes

# --- Mac Studio (M4) ---
Host macstudio
  HostName 192.168.1.201  # Local network
  User chris
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes

Host mac-studio
  HostName 100.71.161.41  # Tailscale
  User chris
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes

# --- MacBook Pro (Intel) ---
Host macbook-pro
  HostName 100.103.135.113  # Tailscale
  User chris
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes

Host *
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/id_ed25519
